generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id           String     @id @default(cuid())
  username     String     @unique
  passwordHash String
  createdAt    DateTime   @default(now())
  saveSlots    SaveSlot[]
}

model SaveSlot {
  id              String          @id @default(cuid())
  userId          String
  slotNumber      Int             @default(1)
  currentChapterId String         @default("prologue")
  knowledgeXp     Int             @default(0)
  medalCount      Int             @default(0)
  playtimeSeconds Int             @default(0)
  updatedAt       DateTime        @updatedAt
  user            User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  codexProgress   CodexProgress[]
  journalEntries  JournalEntry[]
  achievements    Achievement[]

  @@unique([userId, slotNumber])
}

model CodexProgress {
  id            String    @id @default(cuid())
  saveSlotId    String
  codexEntryId  String
  unlockedAt    DateTime  @default(now())
  saveSlot      SaveSlot  @relation(fields: [saveSlotId], references: [id], onDelete: Cascade)

  @@unique([saveSlotId, codexEntryId])
}

model JournalEntry {
  id          String    @id @default(cuid())
  saveSlotId  String
  chapterId   String?
  text        String
  createdAt   DateTime  @default(now())
  saveSlot    SaveSlot  @relation(fields: [saveSlotId], references: [id], onDelete: Cascade)
}

model Achievement {
  id            String    @id @default(cuid())
  saveSlotId    String
  achievementId String
  unlockedAt    DateTime  @default(now())
  saveSlot      SaveSlot  @relation(fields: [saveSlotId], references: [id], onDelete: Cascade)

  @@unique([saveSlotId, achievementId])
}

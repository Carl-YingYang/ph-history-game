[layer_names]

2d_physics/layer_1="player"
2d_physics/layer_2="npc"
2d_physics/layer_3="enemy"
2d_physics/layer_4="collectible"
2d_physics/layer_5="environment"
2d_physics/layer_6="player_hitbox"
2d_physics/layer_7="enemy_hitbox"
2d_physics/layer_8="interaction"
2d_physics/layer_9="trigger"
2d_physics/layer_10="water"

[rendering]

renderer/rendering_method="gl_compatibility"
renderer/rendering_method.mobile="gl_compatibility"
textures/canvas_textures/default_texture_filter=0
environment/defaults/default_clear_color=Color(0.078, 0.063, 0.11, 1)
2d/snap/snap_2d_transforms_to_pixel=true
2d/snap/snap_2d_vertices_to_pixel=true

; Engine configuration file for PROJECT NOOR — Godot 4.4 native RPG engine.
; Migrated from Next.js + Phaser (ph-history-game).
;
; Pixel-perfect 2D configuration: nearest filter, no mipmap, snap to pixel,
; integer-friendly rendering. Designed for Pokemon FireRed / Coromon / Sea of
; Stars style 2D pixel-art RPG built on the Noli Me Tangere / El Filibusterismo
; educational story.

config_version=5

[application]

config/name="Project NOOR"
config/description="Native Godot 4.4 pixel-art RPG — Philippine history educational engine (Noli Me Tangere / El Filibusterismo). Migrated from Next.js + Phaser."
run/main_scene="res://scenes/main/Boot.tscn"
config/features=PackedStringArray("4.4", "GL Compatibility")
config/icon="res://icon.svg"
boot_splash/show_image=false

[autoload]

EventBus="*res://autoload/EventBus.gd"
GameManager="*res://autoload/GameManager.gd"
SaveManager="*res://autoload/SaveManager.gd"
QuestManager="*res://autoload/QuestManager.gd"
InventoryManager="*res://autoload/InventoryManager.gd"
DialogueManager="*res://autoload/DialogueManager.gd"
AudioManager="*res://autoload/AudioManager.gd"
CodexManager="*res://autoload/CodexManager.gd"

[display]

window/size/viewport_width=480
window/size/viewport_height=320
window/size/window_width_override=960
window/size/window_height_override=640
window/stretch/mode="viewport"
window/stretch/aspect="keep"

